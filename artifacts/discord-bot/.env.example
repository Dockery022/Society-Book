# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# Guild ID for slash command registration (right-click your server → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# Premium role IDs — comma-separated, supports multiple roles
# Example with 2 premium tiers: PREMIUM_ROLE_IDS=111222333444555666,777888999000111222
PREMIUM_ROLE_IDS=role_id_1,role_id_2

# The Odds API (https://the-odds-api.com/)
ODDS_API_KEY=your_odds_api_key_here

# Database path (SQLite — stored locally)
DB_PATH=./data/society_book.db
