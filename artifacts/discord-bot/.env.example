# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# Guild ID for slash command registration (your server's ID)
DISCORD_GUILD_ID=your_guild_id_here

# Role ID for premium members in your Discord server
PREMIUM_ROLE_ID=your_premium_role_id_here

# The Odds API (https://the-odds-api.com/)
ODDS_API_KEY=your_odds_api_key_here

# Database path (SQLite)
DB_PATH=./data/society_book.db

# Optional: Set log level (info | warn | error)
LOG_LEVEL=info
